 <IfModule mod_rewrite.c>
    RewriteEngine On

    # Jangan teruskan jika file atau direktori asli memang ada di root
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    # Mengalihkan semua request yang tidak menuju ke /public agar masuk ke /public
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>